# ═══════════════════════════════════════════════════════════════════════
# wrangler.toml — BoxDox: Documentation Hosting with AI
# ═══════════════════════════════════════════════════════════════════════
#
# Copy this file to wrangler.toml and fill in your own resource IDs.
#   cp wrangler.toml.example wrangler.toml
#
# Required resources (create these first):
#   1. D1 database:      npx wrangler d1 create skybox-boxdox-db
#   2. Vectorize index:   npx wrangler vectorize create skybox-boxdox-vectors --dimensions 768
#   3. R2 bucket:         npx wrangler r2 bucket create skybox-boxdox-content
#   4. Secrets:           npx wrangler secret put OPENROUTER_API_KEY
#                          npx wrangler secret put VOWEL_APP_ID
#
# account_id is optional — set CLOUDFLARE_ACCOUNT_ID env var, or omit for auto-detect
# ═══════════════════════════════════════════════════════════════════════

name = "skybox-boxdox"
main = "mcf-worker.js"
compatibility_date = "2025-01-01"

[[d1_databases]]
binding = "DB"
database_name = "skybox-boxdox-db"
database_id = "YOUR_DATABASE_ID"

[[vectorize]]
binding = "VECTORIZE"
index_name = "skybox-boxdox-vectors"

[[r2_buckets]]
binding = "DOCS_BUCKET"
bucket_name = "skybox-boxdox-content"

[[durable_objects.bindings]]
name = "WEBSOCKET_DO"
class_name = "MatchBoxWebSocketDO"

[[migrations]]
tag = "v1"
new_sqlite_classes = ["MatchBoxWebSocketDO"]

[assets]
directory = "dist/assets"

[ai]
binding = "AI"
