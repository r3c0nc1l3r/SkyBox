# ═══════════════════════════════════════════════════════════════════════
# wrangler.toml — SkyChat: RAG-powered AI Chat
# ═══════════════════════════════════════════════════════════════════════
#
# Copy this file to wrangler.toml and fill in your own resource IDs.
#   cp wrangler.toml.example wrangler.toml
#
# Required resources (create these first):
#   1. D1 database:      npx wrangler d1 create skybox-skychat
#   2. Vectorize index:   npx wrangler vectorize create skybox-skychat-vectors --dimensions 768
#   3. Secrets:           npx wrangler secret put OPENROUTER_API_KEY
#
# account_id is optional — set CLOUDFLARE_ACCOUNT_ID env var, or omit for auto-detect
# ═══════════════════════════════════════════════════════════════════════

name = "skybox-skychat"
main = "mcf-worker.js"
compatibility_date = "2025-01-01"

[[d1_databases]]
binding = "DB"
database_name = "skybox-skychat"
database_id = "YOUR_DATABASE_ID"

[[vectorize]]
binding = "VECTORIZE"
index_name = "skybox-skychat-vectors"

[[durable_objects.bindings]]
name = "WEBSOCKET_DO"
class_name = "MatchBoxWebSocketDO"

[[migrations]]
tag = "v1"
new_sqlite_classes = ["MatchBoxWebSocketDO"]
