{
  "name": "ortusbooks-pi",
  "version": "0.1.0",
  "description": "Pi extension for searching and exploring Ortus Solutions documentation and AI skills (BoxLang, ColdBox, CommandBox, WireBox, etc.). Hybrid search: offline skills index first, then GitBook MCP endpoints with caching.",
  "author": "",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "ortus",
    "boxlang",
    "coldbox",
    "commandbox",
    "wirebox",
    "documentation",
    "mcp"
  ],
  "files": [
    "index.ts",
    "sources.ts",
    "mcp-client.ts",
    "skills-repo.ts",
    "skills-index.ts",
    "cache-manager.ts",
    "core/",
    "services/",
    "providers/",
    "lib/",
    "agents/",
    "prompts/",
    "specs/",
    "PLAN.md",
    "README.md"
  ],
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ortus-solutions/ortusbooks-pi.git"
  },
  "homepage": "https://github.com/ortus-solutions/ortusbooks-pi#readme",
  "bugs": {
    "url": "https://github.com/ortus-solutions/ortusbooks-pi/issues"
  }
}
