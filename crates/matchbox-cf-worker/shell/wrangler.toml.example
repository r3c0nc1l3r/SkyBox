# ═══════════════════════════════════════════════════════════════════════
# wrangler.toml — SkyBox WebSocket App (template)
# ═══════════════════════════════════════════════════════════════════════
#
# Copy this file to wrangler.toml and customize:
#   cp wrangler.toml.example wrangler.toml
#
# Then set the worker name and any bindings you need.
# account_id is optional — set CLOUDFLARE_ACCOUNT_ID env var, or omit for auto-detect
# ═══════════════════════════════════════════════════════════════════════

name = "skybox-app"
main = "mcf-worker.js"
compatibility_date = "2025-01-01"

# Durable Object binding for the WebSocket host
[[durable_objects.bindings]]
name = "WEBSOCKET_DO"
class_name = "MatchBoxWebSocketDO"

# Durable Object migration (required for first deploy)
[[migrations]]
tag = "v1"
new_sqlite_classes = ["MatchBoxWebSocketDO"]

# ── Optional bindings (uncomment and configure as needed) ──

# Static assets (CSS, JS, images)
# [assets]
# directory = "dist/assets"

# KV Namespace
# [[kv_namespaces]]
# binding = "KV_MYSTORE"
# id = "..."

# R2 Bucket
# [[r2_buckets]]
# binding = "R2_ASSETS"
# bucket_name = "my-assets"

# D1 Database
# [[d1_databases]]
# binding = "D1_DB"
# database_name = "my-db"
# database_id = "..."

# Queue
# [[queues]]
# binding = "QUEUE_MYQUEUE"
# queue_name = "my-queue"

# Vectorize (vector database for RAG)
# [[vectorize]]
# binding = "VECTORIZE"
# index_name = "my-index"
